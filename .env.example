# GCP Project
GCP_PROJECT_ID=dreamscape-hackathon
GCP_REGION=us-central1

# Gemini API (Google AI Studio)
GOOGLE_API_KEY=your-gemini-api-key-here

# Firebase (frontend)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=dreamscape-hackathon.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=dreamscape-hackathon
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=dreamscape-hackathon.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Cloud Storage
GCS_BUCKET_NAME=dreamscape-media

# Authentication: No service account key file needed!
# Local dev: run "gcloud auth application-default login"
# Cloud Run: service account attached at deploy time
